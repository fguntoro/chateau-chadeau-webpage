---
import Layout from '../layouts/layout.astro';

// Import your new separate stylesheet here
import '../styles/hero.css';
---

<Layout title="Chadeau Lab | Computational Epidemiology & Machine Learning">
  <section class="hero-container">
    
    <div class="hero-bg-network"></div>

    <div class="hero-content-card">
      <span class="hero-tagline">Data Driven • Impact Bound</span>
      
      <h1 class="hero-title">
        From Complex Big Data to Public Health Solutions
      </h1>
      
      <div class="hero-actions">
        <!-- <a href="/publications" class="btn btn-primary">Learn About Our Research</a> -->
        <a href="/team" class="btn btn-primary">Meet The Group</a>
      </div>
    </div>

  </section>

  <section class="info-grid-section">
    <div class="section-header">
      <h2>Driving Research Forward</h2>
      <p>We are a dedicated team of scientists harnessing advanced statistics and machine learning to decode complex high-dimensional health data.</p>
    </div>

    <div class="three-column-grid">
      <div class="grid-card">
        <h3>Computational Epidemiology</h3>
        <p>Characterizing complex molecular signatures of the exposome, including cross-layer implications of environmental and social determinants.</p>
      </div>
      <div class="grid-card">
        <h3>Biostatistics</h3>
        <p>Developing novel, computationally robust tools engineered for high-dimensional data analysis.</p>
      </div>
      <div class="grid-card">
        <h3>Translational Science</h3>
        <p>Leveraging large population biobank data registries to explore underlying biological mechanisms and translate data directly into public health frameworks.</p>
      </div>
    </div>
  </section>
</Layout>
---
import Layout from '../layouts/layout.astro';

// Clean array of team structures for rapid editing
const team = [
  {
    name: "Prof. Marc Chadeau-Hyam",
    role: "Principal Investigator",
    category: "pi",
    bio: "Professor of Computational Epidemiology and Global Health at Imperial College London. Leading multi-omics integration and environmental health framework designs.",
    email: "m.chadeau@imperial.ac.uk",
    avatar: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=300&q=80"
  },
  {
    name: "Dr. Fernando Guntoro",
    role: "Postdoctoral Researcher",
    category: "postdoc",
    bio: "Specializing in scalable stability selection pipelines and high-dimensional biobank data manipulation.",
    email: "f.guntoro@imperial.ac.uk",
    avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=300&q=80"
  },
  {
    name: "Jane Smith",
    role: "PhD Candidate",
    category: "phd",
    bio: "Focusing on rare variant association testing workflows within population-scale cohort data assets.",
    email: "j.smith@imperial.ac.uk",
    avatar: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=300&q=80"
  }
];

const piMembers = team.filter(m => m.category === 'pi');
const staffMembers = team.filter(m => m.category !== 'pi');
---

<Layout title="Team Members">
    <h1 style="color: #0f172a; margin-bottom: 0.5rem;">Our Team</h1>
    <p style="color: #475569; margin-bottom: 3rem;">Meet the researchers, clinicians, and data scientists pushing the boundaries of computational epidemiology.</p>

    <!-- Principal Investigator Section (Hero Profile) -->
    <section style="margin-bottom: 4rem;">
        <h2 style="border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem; color: #0f172a;">Principal Investigator</h2>
        {piMembers.map(member => (
            <div style="display: grid; grid-template-columns: 200px 1fr; gap: 2rem; background: white; padding: 2rem; border-radius: 12px; border: 1px solid #e2e8f0; margin-top: 1.5rem; align-items: center;">
                <img src={member.avatar} alt={member.name} style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;" />
                <div>
                    <h3 style="margin: 0; font-size: 1.5rem; color: #0f172a;">{member.name}</h3>
                    <p style="margin: 0.25rem 0 1rem 0; color: #2563eb; font-weight: 600;">{member.role}</p>
                    <p style="color: #475569; margin-bottom: 1.5rem;">{member.bio}</p>
                    <a href={`mailto:${member.email}`} style="color: #475569; font-size: 0.9rem; text-decoration: none; border: 1px solid #cbd5e1; padding: 0.5rem 1rem; border-radius: 6px; background: #f8fafc;">Contact Email &rarr;</a>
                </div>
            </div>
        ))}
    </section>

    <!-- Lab Researchers / Students Grid -->
    <section>
        <h2 style="border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem; color: #0f172a;">Researchers & Students</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 1.5rem;">
            {staffMembers.map(member => (
                <div style="background: white; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column;">
                    <img src={member.avatar} alt={member.name} style="width: 80px; height: 80px; object-fit: cover; border-radius: 50%; margin-bottom: 1rem;" />
                    <h3 style="margin: 0 0 0.25rem 0; color: #0f172a; font-size: 1.2rem;">{member.name}</h3>
                    <p style="margin: 0 0 1rem 0; color: #475569; font-size: 0.9rem; font-weight: 500;">{member.role}</p>
                    <p style="color: #64748b; font-size: 0.9rem; flex-grow: 1; margin-bottom: 1.5rem;">{member.bio}</p>
                    <a href={`mailto:${member.email}`} style="color: #2563eb; font-size: 0.85rem; text-decoration: none; font-weight: 500;">{member.email}</a>
                </div>
            ))}
        </div>
    </section>
</Layout>
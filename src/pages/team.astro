---
import Layout from '../layouts/layout.astro'; // Fixed case sensitivity typo to prevent Linux container crash

// Import the raw data from your newly created isolated folders
import activeMembers from '../data/team/active.json';
import pastMembers from '../data/team/alumni.json';

// Handle sorting arrays smoothly via Javascript execution
const alumni_team = [...pastMembers].sort();

const piMembers = activeMembers.filter(m => m.category === 'pi');

const staffAndStudents = activeMembers
  .filter(m => m.category === 'phd' || m.category === 'staff')
  .sort((a, b) => {
    // 1. If categories are different, push 'staff' ahead of 'phd'
    if (a.category !== b.category) {
      return a.category === 'staff' ? -1 : 1;
    }
    // 2. If categories are identical, sort alphabetically by name
    return a.name.localeCompare(b.name);
  });
---

<Layout title="Team Members">
    <h1 style="color: #0f172a; margin-bottom: 0.5rem;">Our Team</h1>
    <p style="color: #475569; margin-bottom: 3rem;">Meet the researchers, clinicians, and data scientists.</p>

    <section style="margin-bottom: 4rem;">
        <h2 style="border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem; color: #0f172a;">Principal Investigator</h2>
        {piMembers.map(member => (
            <div style="display: grid; grid-template-columns: 200px 1fr; gap: 2rem; background: white; padding: 2rem; border-radius: 12px; border: 1px solid #e2e8f0; margin-top: 1.5rem; align-items: center;">
                <img src={member.avatar} alt={member.name} style="
                    width: 100%; 
                    aspect-ratio: 1 / 1; 
                    object-fit: contain; 
                    background-color: #ffffff; 
                    border-radius: 8px;
                    border: 1px solid #f1f5f9;
                " />
                <div>
                    <h3 style="margin: 0; font-size: 1.5rem; color: #0f172a;">{member.name}</h3>
                    <p style="margin: 0.25rem 0 1rem 0; color: #2563eb; font-weight: 600;">{member.role}</p>
                    <p style="color: #475569; margin-bottom: 1.5rem;">{member.bio}</p>
                    <a href={`mailto:${member.email}`} style="color: #475569; font-size: 0.9rem; text-decoration: none; border: 1px solid #cbd5e1; padding: 0.5rem 1rem; border-radius: 6px; background: #f8fafc;">Contact Email &rarr;</a>
                </div>
            </div>
        ))}
    </section>

    <section style="margin-bottom: 4rem;">
        <h2 style="border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem; color: #0f172a;">Staff & Students</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.25rem; margin-top: 1.5rem;">
            {staffAndStudents.map(member => (
                <div style="background: white; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1rem; display: flex; flex-direction: column; max-width: 240px;">
                    <img src={member.avatar} alt={member.name} style="width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 6px; margin-bottom: 0.75rem; background: #f1f5f9;" />
                    <h3 style="margin: 0 0 0.15rem 0; color: #0f172a; font-size: 1.05rem; line-height: 1.3;">{member.name}</h3>
                    <p style="margin: 0 0 0.75rem 0; color: #475569; font-size: 0.85rem; font-weight: 500;">{member.role}</p>
                    <p style="color: #64748b; font-size: 0.85rem; flex-grow: 1; margin-bottom: 1rem; line-height: 1.4;">{member.bio}</p>
                    <a href={`mailto:${member.email}`} style="color: #2563eb; font-size: 0.6rem; text-decoration: none; font-weight: 500; word-break: break-all;">{member.email}</a>
                </div>
            ))}
        </div>
    </section>

    <section style="margin-top: 4rem;">
        <h2 style="border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem; color: #0f172a;">Past Members</h2>
        <ul style="list-style-type: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.75rem; margin-top: 1.5rem;">
            {alumni_team.map(name => (
                <li style="background: #f8fafc; padding: 0.5rem 1rem; border: 1px solid #e2e8f0; border-radius: 6px; color: #334155; font-weight: 500; font-size: 0.85rem; text-align: center;">
                    🎓 {name}
                </li>
            ))}
        </ul>
    </section>
</Layout>